# CourtListener
COURTLISTENER_API_TOKEN=
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_PAGE_SIZE=100
COURTLISTENER_MAX_PAGES=120
COURTLISTENER_TIMEOUT_SECONDS=45
COURTLISTENER_RETRY_COUNT=4
COURTLISTENER_REST_ENABLED=true
COURTLISTENER_BULK_ENABLED=true
COURTLISTENER_BULK_PATH=scripts/output/raw/courtlistener/bulk

# pile-of-law
PILE_OF_LAW_DATASET_NAME=pile-of-law/pile-of-law
PILE_OF_LAW_DATASET_SPLIT=train
PILE_OF_LAW_CURATED_TARGET=300
PILE_OF_LAW_DIVERSE_TARGET=250
PILE_OF_LAW_STREAMING=true

# Quality and output
TARGET_COURTLISTENER_HIGH_VALUE=500
QUALITY_REQUIRE_PLAIN_TEXT=true
QUALITY_STRICT_CITATION=true
QUALITY_QUARANTINE_MISSING_CITATION=true
QUALITY_DEDUPE_ENABLED=true
QUALITY_MIN_TEXT_CHARS=2000
QUALITY_ADAPTIVE_RECENCY=true
QUALITY_MAX_DOMAIN_SHARE=0.40
